# Copy this file to .env and fill in your values.
# .env is gitignored and will NOT be committed.

# RunPod
RUNPOD_API_KEY=
RUNPOD_NETWORK_VOLUME_ID=

# Google Earth Engine service account
GEE_SERVICE_ACCOUNT=your-sa@your-project.iam.gserviceaccount.com

# Option A (local dev): path to a JSON key file
GEE_KEY_FILE=/path/to/your-service-account-key.json

# Option B (RunPod / CI): paste the JSON key content or its base64 encoding.
# Base64 is recommended for secret stores that mangle special characters:
#   base64 -w0 /path/to/key.json
# On RunPod this is injected automatically via RunPod Secrets — see README.
# GEE_PRIVATE_KEY_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# Google Maps / Places API key (for Google Places notebooks)
GOOGLE_MAPS_API_KEY=
